{
  "editor.minimap.enabled": false,
  "macros": {
    "commentLine": ["editor.action.commentLine", "cursorDown"]
  },
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"]
    },
    {
      "before": ["<C-n>"],
      "commands": [":nohl"]
    }
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "terminal.integrated.sendKeybindingsToShell": true,
  "editor.suggestSelection": "first",
  "security.workspace.trust.untrustedFiles": "open",
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "code-runner.clearPreviousOutput": true,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "cSpell.userWords": [
    "AIDL",
    "alipay",
    "alloc",
    "antd",
    "AOSP",
    "appops",
    "appwidget",
    "ATTOW",
    "Autorelease",
    "autoreleasepool",
    "Backtracer",
    "Classname",
    "clazz",
    "codeql",
    "Comparation",
    "compat",
    "concat",
    "conscrypt",
    "Consts",
    "Cronet",
    "cydia",
    "debuggable",
    "decompile",
    "deoptimize",
    "doman",
    "dylib",
    "eigen",
    "fmap",
    "foldl",
    "foldr",
    "frida",
    "Fridayam",
    "fridayeve",
    "Geolocation",
    "graphviz",
    "hashcodes",
    "Hasher",
    "heixiong",
    "Hotspot",
    "iconfont",
    "iloy",
    "Imei",
    "Infoflow",
    "Inplace",
    "ivars",
    "javascriptinterface",
    "Jimple",
    "jobscheduler",
    "jsbridge",
    "klazz",
    "launcherapps",
    "logi",
    "Logify",
    "Lolipop",
    "mappend",
    "mempty",
    "Miniprogram",
    "Monoid",
    "mzero",
    "natsuki",
    "ndjson",
    "NFCNDEF",
    "NSURL",
    "nullptr",
    "onconsolemessage",
    "ontap",
    "Oplus",
    "OPPO",
    "packageinstaller",
    "Parcelable",
    "pdjson",
    "Phonebook",
    "Processlist",
    "Reparcel",
    "repr",
    "Restarter",
    "Rustancean",
    "searchbar",
    "Semigroup",
    "sensorservice",
    "Seperater",
    "showmenu",
    "Sideload",
    "sideloading",
    "significants",
    "Steensgaard's",
    "struct",
    "succ",
    "THEOS",
    "togglable",
    "uintptr",
    "uncurry",
    "unlines",
    "unwords",
    "uppercased",
    "vinstrument",
    "wechat",
    "weui",
    "wexin",
    "wifinl",
    "wifip",
    "wifiscanner",
    "WKHTTP",
    "WKUI"
  ],
  "files.watcherExclude": {
    "**/.bloop": true,
    "**/.metals": true,
    "**/.ammonite": true
  },
  "markdown-preview-enhanced.previewTheme": "atom-dark.css",
  "markdown-preview-enhanced.mathRenderingOption": "MathJax",
  "markdown-preview-enhanced.mathBlockDelimiters": [["$$`", "`$$"]],
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "terminal.integrated.inheritEnv": false,
  "diffEditor.ignoreTrimWhitespace": true,
  "explorer.confirmDelete": false,
  "security.workspace.trust.enabled": false,
  "files.associations": {
    "*.cjson": "jsonc",
    "*.wxss": "css",
    "*.wxs": "javascript"
  },
  "emmet.includeLanguages": {
    "wxml": "html"
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.tabSize": 2,
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "kotlin.languageServer.enabled": false,
  "kotlin.debugAdapter.enabled": false,
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "window.zoomLevel": 1,
  "remote.SSH.defaultExtensions": ["gitpod.gitpod-remote-ssh"],
  "[python]": {
    "editor.formatOnType": true
  },
  "remote.SSH.remotePlatform": {
    "*.gitpod.io": "linux"
  },
  "editor.fontSize": 12,
  "editor.fontWeight": "normal",
  "editor.fontFamily": "\"Hack Nerd Font\"",
  "redhat.telemetry.enabled": true,
  "http.proxy": "http://127.0.0.1:7890",
  "git.autofetch": true,
  "window.autoDetectColorScheme": false,
  "security.promptForLocalFileProtocolHandling": false
}
