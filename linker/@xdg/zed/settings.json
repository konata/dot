// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "ui_font_weight": 450.0,
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "terminal": {
    "env": {
      "FIG_NEW_SESSION": "\"1\"",
    },
  },
  "minimap": {
    "show": "never",
  },
  "file_types": {
    "javascript": ["*.wxs"],
    "jsonc": ["*.cjson"],
    "css": ["*.wxss"],
  },
  "preferred_line_length": 200,
  "agent": {
    "dock": "right",
    "default_model": {
      "effort": "medium",
      "provider": "zed.dev",
      "model": "gpt-5.4",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_ui_font_size": 16.0,
  "agent_buffer_font_size": 14.0,
  "ui_font_family": ".ZedSans",
  "buffer_font_family": "GeistMono Nerd Font",
  "buffer_font_weight": 500,
  "base_keymap": "JetBrains",
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Symbols Icon Theme",
  },
  "tab_size": 2,
  "vim_mode": true,
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "light",
    "light": "Rosé Pine Dawn",
    "dark": "Cursor Dark",
  },
  "experimental.theme_overrides": {
    "search.match_background": "#ff0000",
    "editor.document_highlight.read_background": "#00FF0033",
    "editor.document_highlight.write_background": "#FF000033",
  },
}
